# Production environment settings
# This file gets used when deployed to production
# IMPORTANT: In Vercel, set these values in the Vercel dashboard

# Clerk Authentication
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY set in Vercel dashboard
# CLERK_SECRET_KEY set in Vercel dashboard

# Google Gemini API Key
# GEMINI_API_KEY set in Vercel dashboard

# Admin Configuration
# ADMIN_EMAIL set in Vercel dashboard
# ADMIN_PASSWORD set in Vercel dashboard
# NEXT_PUBLIC_ADMIN_KEY set in Vercel dashboard

# AI Model Configuration
DEFAULT_GEMINI_MODEL="gemini-1.5-flash"
USE_FALLBACK_MODEL="true"
MAX_OUTPUT_TOKENS="2048"

# Database URL (Set in Vercel dashboard for production)
# DATABASE_URL="postgresql://username:password@host:port/database"
